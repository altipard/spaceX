# SpaceX Launch Tracker - Environment Variables
# pydantic-settings can read from this .env file

# SpaceX API v4 base URL
SPACEX_BASE_URL=https://api.spacexdata.com/v4

# Cache TTL in seconds (default: 300 = 5 minutes)
CACHE_TTL=300

# Cache directory path
CACHE_DIR=data

# Uvicorn host and port
HOST=0.0.0.0
PORT=8000